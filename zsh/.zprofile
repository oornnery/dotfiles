# ~/.zprofile
# This file is sourced for login shells.
# Use it for session startup that should not run on every interactive shell.

# Load Homebrew or other login-only tools here in the future if needed.
# Example:
# [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# WSL-specific login hooks can live here if you need them later.
# Keep this file minimal unless you truly need login-only behavior.