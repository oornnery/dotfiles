{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "palette": {
    "pink":     "#f5c2e7",
    "mauve":    "#cba6f7",
    "red":      "#f38ba8",
    "peach":    "#fab387",
    "yellow":   "#f9e2af",
    "green":    "#a6e3a1",
    "teal":     "#94e2d5",
    "sapphire": "#74c7ec",
    "blue":     "#89b4fa",
    "lavender": "#b4befe",
    "text":     "#cdd6f4",
    "overlay2": "#9399b2",
    "base":     "#1e1e2e"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:teal",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "home_icon": "~",
            "mapped_locations": {
              "~/dotfiles":  " dotfiles",
              "~/Documents": " Documents",
              "~/Downloads": " Downloads",
              "~/Pictures":  " Pictures"
            }
          },
          "template": "<b>{{ .Path }}</b> "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:pink",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "branch_icon": " ",
            "branch_max_length": 24
          },
          "template": "<b>{{ .UpstreamIcon }}{{ .HEAD }}</b>{{ if .Working.Changed }} ✱{{ .Working.String }}{{ end }}{{ if .Staging.Changed }} ✓{{ .Staging.String }}{{ end }}{{ if gt .Ahead 0 }} ⇡{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ⇣{{ .Behind }}{{ end }} "
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " {{ if .Venv }}({{ .Venv }}) {{ end }}"
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:green",
          "template": " {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "plain",
          "foreground": "p:red",
          "template": " {{ .Full }} "
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:sapphire",
          "template": " {{ .Full }} "
        },
        {
          "type": "docker",
          "style": "plain",
          "foreground": "p:blue",
          "template": " {{ .Context }} "
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:red",
          "template": "{{ if .Error }}<b>✘ {{ .Code }}</b> · {{ end }}"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:yellow",
          "properties": {
            "threshold": 2000,
            "style": "round"
          },
          "template": " {{ .FormattedMs }} · "
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:overlay2",
          "properties": {
            "time_format": "15:04"
          },
          "template": "{{ .CurrentDate | date .Format }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:pink",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "<b>❯</b> "
        }
      ]
    }
  ]
}
