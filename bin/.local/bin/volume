#!/usr/bin/env bash
# volume — PipeWire sink/source control via wpctl + mako progress notify.
#
# Usage:
#   volume raise            sink +5%
#   volume lower            sink -5%
#   volume mute-toggle      sink mute toggle
#   volume mic-mute-toggle  source mute toggle
#   volume set <0-100>      sink absolute
#   volume get              print sink 0-100

set -euo pipefail

STEP="${VOLUME_STEP:-5}"
SINK="@DEFAULT_AUDIO_SINK@"
SOURCE="@DEFAULT_AUDIO_SOURCE@"

if ! command -v wpctl >/dev/null; then
    notify-send -a volume -i dialog-error "Volume" "wpctl missing"
    exit 1
fi

_pct() {
    wpctl get-volume "$1" | awk '{printf "%d", $2 * 100}'
}

_muted() {
    wpctl get-volume "$1" | grep -q MUTED && echo 1 || echo 0
}

_notify_sink() {
    local p; p="$(_pct "$SINK")"
    local muted; muted="$(_muted "$SINK")"
    local icon="audio-volume-medium"
    [[ $muted -eq 1 ]] && icon="audio-volume-muted"
    local body="${p}%"
    [[ $muted -eq 1 ]] && body="muted"
    notify-send -a volume -i "$icon" -t 1500 \
        -h "string:x-canonical-private-synchronous:volume" \
        -h "int:value:$p" \
        "Volume" "$body"
}

_notify_mic() {
    local muted; muted="$(_muted "$SOURCE")"
    local icon="microphone-sensitivity-high"
    local body="active"
    if [[ $muted -eq 1 ]]; then
        icon="microphone-sensitivity-muted"
        body="muted"
    fi
    notify-send -a volume -i "$icon" -t 1500 \
        -h "string:x-canonical-private-synchronous:mic" \
        "Microphone" "$body"
}

case "${1:-get}" in
    raise) wpctl set-volume -l 1.5 "$SINK" "${STEP}%+"; _notify_sink ;;
    lower) wpctl set-volume "$SINK" "${STEP}%-";       _notify_sink ;;
    mute-toggle)
        wpctl set-mute "$SINK" toggle
        _notify_sink
        ;;
    mic-mute-toggle)
        wpctl set-mute "$SOURCE" toggle
        _notify_mic
        ;;
    set)
        [[ -z "${2:-}" ]] && { echo "Usage: volume set <0-100>" >&2; exit 1; }
        wpctl set-volume -l 1.5 "$SINK" "${2}%"
        _notify_sink
        ;;
    get|"") _pct "$SINK" ;;
    -h|--help|help) sed -n '2,10p' "$0" ;;
    *) echo "volume: unknown command: $1" >&2; exit 1 ;;
esac
