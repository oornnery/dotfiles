#!/usr/bin/env bash
# dots:summary=Remove a Firefox PWA web app by name (uses walker picker)
# dots:examples=dots-webapp-remove

set -euo pipefail

if ! command -v firefoxpwa >/dev/null; then
    dots-notification-send "Webapp" "firefoxpwa não instalado" -g "⚠"
    exit 1
fi

# List sites and let user pick via walker dmenu
SITES=$(firefoxpwa site list 2>&1 | grep -E '^- ' | sed 's/^- //')
[[ -z "$SITES" ]] && { echo "no webapps"; exit 0; }

ulid=$(printf '%s\n' "$SITES" | walker --dmenu --placeholder "Remove webapp:" 2>/dev/null | awk -F'[() ]' '{print $1}')
[[ -z "$ulid" ]] && exit 0

firefoxpwa site remove "$ulid"
dots-notification-send "Webapp removed" "$ulid" -g "󰮜"
