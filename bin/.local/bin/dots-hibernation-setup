#!/usr/bin/env bash
# dots:summary=Setup hibernation: create swap file = RAM, configure resume param
# dots:requires-sudo=true
# dots:examples=sudo dots-hibernation-setup

set -euo pipefail

[[ $EUID -ne 0 ]] && { echo "Run as root (sudo)" >&2; exit 1; }

RAM_GB=$(awk '/^MemTotal/ {print int(($2/1024/1024)+1); exit}' /proc/meminfo)
SWAPFILE="/swapfile"

echo "RAM detected: ${RAM_GB} GB"
echo "Will create $SWAPFILE = ${RAM_GB} GiB"

if [[ -f $SWAPFILE ]]; then
    echo "Swap file already exists" >&2
    exit 1
fi

# Btrfs requires special handling (NOCOW + nodatacow)
ROOT_FS=$(findmnt -no FSTYPE /)
if [[ "$ROOT_FS" == "btrfs" ]]; then
    echo "btrfs detected — creating no-cow swap file"
    btrfs filesystem mkswapfile --size "${RAM_GB}g" --uuid clear "$SWAPFILE"
else
    fallocate -l "${RAM_GB}G" "$SWAPFILE"
    chmod 600 "$SWAPFILE"
    mkswap "$SWAPFILE"
fi

swapon "$SWAPFILE"

# fstab entry (only if not present)
if ! grep -q "$SWAPFILE" /etc/fstab; then
    echo "$SWAPFILE none swap defaults 0 0" >> /etc/fstab
fi

# Find resume offset (only for non-btrfs; btrfs uses btrfs_map_physical or filefrag)
if [[ "$ROOT_FS" != "btrfs" ]]; then
    OFFSET=$(filefrag -v "$SWAPFILE" | awk 'NR==4 {gsub(/\./,""); print $4; exit}')
    UUID=$(findmnt -no UUID /)
    echo "Add to bootloader: resume=UUID=$UUID resume_offset=$OFFSET"
fi

# Enable systemd targets
systemctl enable systemd-hibernate.target 2>/dev/null || true

echo "Hibernation setup OK. Test with: systemctl hibernate"
