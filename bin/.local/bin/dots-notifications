#!/usr/bin/env bash
# dots:summary=Notification control (history / dismiss / restore / list)
# dots:args=<command>
# dots:examples=dots-notifications restore | dots-notifications clear
#
# Thin wrapper over makoctl plus walker integration for picking from history.
#
# Commands:
#   restore        Bring back the most recently expired notification
#   dismiss        Dismiss the topmost visible notification
#   clear          Dismiss ALL visible notifications
#   list           Print current notifications (JSON)
#   pick           Walker picker over current notifications → invoke action
#   toggle-dnd     Toggle Do-Not-Disturb (alias to `dnd`)

set -euo pipefail

if ! command -v makoctl >/dev/null; then
    notify-send -a dots-notifications -i dialog-error \
        "Notifications" "mako not running"
    exit 1
fi

_pick_with_walker() {
    if ! command -v walker >/dev/null; then
        echo "walker not installed" >&2
        return 1
    fi
    walker --dmenu --placeholder "$1" 2>/dev/null
}

case "${1:-help}" in
    restore)
        # makoctl restore pulls the last dismissed/expired off the history buffer
        # and re-shows it. Bound to MS+Backspace.
        if ! makoctl restore 2>/dev/null; then
            notify-send -a dots-notifications -t 1500 \
                "Notifications" "No history to restore"
        fi
        ;;

    dismiss)
        # Dismiss the topmost. MS+Delete or whatever you bind it to.
        makoctl dismiss 2>/dev/null || true
        ;;

    clear|dismiss-all)
        # Dismiss every visible notification. M+Backspace.
        makoctl dismiss --all 2>/dev/null || true
        ;;

    list)
        # JSON of currently visible notifications.
        makoctl list
        ;;

    pick)
        # Show current notifications in walker; selecting one invokes its
        # default action (same as left-click on the popup).
        lines="$(makoctl list 2>/dev/null \
            | jq -r '.data[][] | "\(.id.data)\t\(.["app-name"].data) — \(.summary.data)"' 2>/dev/null)"
        if [[ -z "$lines" ]]; then
            notify-send -a dots-notifications -t 1500 \
                "Notifications" "No active notifications"
            exit 0
        fi
        pick="$(printf '%s\n' "$lines" | _pick_with_walker 'Notification:')"
        [[ -z "$pick" ]] && exit 0
        id="${pick%%$'\t'*}"
        makoctl invoke -n "$id" default 2>/dev/null || \
            makoctl invoke -n "$id" 2>/dev/null || true
        ;;

    toggle-dnd|dnd)
        exec dnd
        ;;

    -h|--help|help|"")
        sed -n '2,17p' "$0"
        ;;

    *)
        echo "dots-notifications: unknown command: $1" >&2
        echo "Try: dots-notifications help" >&2
        exit 1
        ;;
esac
