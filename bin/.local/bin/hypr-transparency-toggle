#!/usr/bin/env bash
# dots:summary=Toggle window active/inactive opacity
# hypr-transparency-toggle — alterna opacity das janelas (active/inactive).
# State em $XDG_RUNTIME_DIR/hypr-transparency-state.

set -euo pipefail

STATE="${XDG_RUNTIME_DIR:-/tmp}/hypr-transparency-state"

if [[ -f "$STATE" ]]; then
    rm -f "$STATE"
    hyprctl --batch "\
        keyword decoration:active_opacity 1.0; \
        keyword decoration:inactive_opacity 1.0" >/dev/null
    notify-send -a hypr-transp "Transparency" "OFF (opaque)"
else
    touch "$STATE"
    hyprctl --batch "\
        keyword decoration:active_opacity 0.95; \
        keyword decoration:inactive_opacity 0.85" >/dev/null
    notify-send -a hypr-transp "Transparency" "ON (active 95% / inactive 85%)"
fi
