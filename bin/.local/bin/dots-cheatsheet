#!/usr/bin/env bash
# dots:summary=Cheatsheet picker via walker (Hyprland/Tmux/Vim/Zsh/Functions + MD docs)
# dots:examples=dots-cheatsheet
#
# Two-level walker dmenu:
#   1. Category picker (Hyprland binds, Tmux, Vim, Zsh aliases, …, MD docs)
#   2. Lines within category → Enter copia pra clipboard
#
# Live sources:
#   Hyprland binds      ← hyprctl binds -j (descriptions de bindings.lua)
#   Tmux binds          ← ~/.tmux.conf
#   Vim / Neovim binds  ← ~/.vimrc + ~/.config/nvim/plugin/*.lua
#   Zsh aliases         ← `alias` em shell interactive
#   Shell functions     ← ~/.zsh_functions
# Static sources:
#   docs/cheatsheets/*.md   ← per-tool md (eza, bat, fzf, …)

set -uo pipefail

DOCS_DIR="${CHEATSHEET_DIR:-$HOME/dotfiles/docs/cheatsheets}"

_walker_dmenu() {
    walker --dmenu --placeholder "$1" 2>/dev/null
}

# ─── Modmask decoder (Hyprland numerical → human) ──────────────────────────

_decode_mods() {
    local m="$1" parts=()
    (( m & 64 )) && parts+=("Super")
    (( m & 4  )) && parts+=("Ctrl")
    (( m & 8  )) && parts+=("Alt")
    (( m & 1  )) && parts+=("Shift")
    if (( ${#parts[@]} == 0 )); then echo "—"
    else local IFS=+; echo "${parts[*]}"; fi
}

# ─── Sources ───────────────────────────────────────────────────────────────

_src_hyprland() {
    hyprctl binds -j 2>/dev/null \
        | jq -r '.[]
               | select(.key != "")
               | "\(.modmask // 0)|\(.key)|\(.description // .dispatcher) \(.arg // "")"' \
        | while IFS='|' read -r mods key rest; do
              printf "%-30s  →  %s\n" "$(_decode_mods "$mods")+$key" "$rest"
          done \
        | sort -u
}

_src_tmux() {
    [[ -f "$HOME/.tmux.conf" ]] && grep -E '^(bind|set|setw)' "$HOME/.tmux.conf"
}

_src_vim() {
    [[ -f "$HOME/.vimrc" ]] && \
        grep -E '^(let mapleader|nnoremap|vnoremap|inoremap|map\b)' "$HOME/.vimrc"
    for f in "$HOME"/.config/nvim/plugin/*.lua \
             "$HOME"/.config/nvim/lua/config/keymaps.lua; do
        [[ -f "$f" ]] || continue
        grep -E 'vim\.keymap\.set|map\(' "$f" 2>/dev/null \
            | sed "s|^|${f##*/}: |"
    done
}

_src_zsh_aliases() {
    zsh -ic 'alias' 2>/dev/null | sort
}

_src_zsh_functions() {
    [[ -f "$HOME/.zsh_functions" ]] || return
    awk '
        /^[[:space:]]*#/        { last_comment = $0; next }
        /^[a-zA-Z_][a-zA-Z0-9_-]*\(\)/ {
            name = $1; sub(/\(\).*/, "", name)
            printf "%-20s  %s\n", name, last_comment
            last_comment = ""
        }
    ' "$HOME/.zsh_functions"
}

_show_doc() {
    local file="$1" title="$2"
    # `floating-md` é uma classe própria (window rule em windowrules.lua dá
    # tamanho reading-friendly — mais estreito + alto que o `floating-tui`).
    local class="floating-md"

    if command -v glow >/dev/null 2>&1; then
        # -s dark   — tema escuro pré-built
        # -w 90     — wrap em 90 colunas (legível)
        # -p        — pager mode (q sai, /search, n/N navegar matches)
        alacritty --class "$class" --title " $title" \
            -o font.size=12 \
            -o window.padding.x=20 -o window.padding.y=14 \
            -e glow -s dark -w 90 -p "$file"
    else
        alacritty --class "$class" --title " $title" \
            -o font.size=12 \
            -o window.padding.x=20 -o window.padding.y=14 \
            -e bat --paging=always --language=md --theme=base16 \
            --style=plain --color=always "$file"
    fi
}

# ─── Inner menu: lines within category ─────────────────────────────────────

_browse() {
    local title="$1"
    local content; content="$(cat)"
    local pick
    pick="$(printf '← Back\n%s' "$content" | _walker_dmenu "$title:")"

    case "$pick" in
        ''|'← Back') return 10 ;;   # signal: back to main
        *)
            printf '%s' "$pick" | wl-copy
            dots-notification-send "Cheatsheet" "Copied" -g "" -t 2000
            ;;
    esac
}

# ─── Main menu ─────────────────────────────────────────────────────────────

_main_menu() {
    printf '󰌌  Hyprland keybindings (live)\n'
    printf '  Tmux keybindings (live)\n'
    printf '  Vim / Neovim keybindings (live)\n'
    printf '󰒓  Zsh aliases (live)\n'
    printf 'ƒ  Shell functions (live)\n'
    if [[ -d "$DOCS_DIR" ]]; then
        for f in "$DOCS_DIR"/*.md; do
            [[ -f "$f" ]] || continue
            printf '󰈙  %s\n' "$(basename "$f" .md)"
        done
    fi
}

# ─── Main loop ─────────────────────────────────────────────────────────────

while :; do
    pick="$(_main_menu | _walker_dmenu 'Cheatsheet:')"
    [[ -z "$pick" ]] && exit 0

    case "$pick" in
        *Hyprland*)        _src_hyprland       | _browse "Hyprland" ;;
        *Tmux*)            _src_tmux           | _browse "Tmux" ;;
        *Vim*|*Neovim*)    _src_vim            | _browse "Vim/Neovim" ;;
        *Zsh*aliases*)     _src_zsh_aliases    | _browse "Zsh aliases" ;;
        *Shell*functions*) _src_zsh_functions  | _browse "Shell functions" ;;
        *)
            name="${pick##*  }"   # strip glyph prefix
            file="$DOCS_DIR/$name.md"
            if [[ -f "$file" ]]; then
                _show_doc "$file" "$name"
                continue
            else
                dots-notification-send "Cheatsheet" "Not found: $name" -g "⚠"
            fi
            ;;
    esac

    [[ $? -eq 10 ]] || exit 0
done
