#!/usr/bin/env bash
# dots:summary=Cheatsheet picker via walker (markdown docs + live zsh aliases/functions)
# dots:examples=dots-cheatsheet
#
# Two-level walker dmenu:
#   1. Category picker (.md docs + live aliases/functions)
#   2. For live sources: lines within category → Enter copies to clipboard
#      For docs: opens in floating alacritty via glow|bat|rich + less -R
#
# Sources:
#   docs/cheatsheets/*.md   ← canonical reference (hyprland, tmux, vim, …)
#   Zsh aliases (live)      ← awk on ~/.zshrc (current state)
#   Shell functions (live)  ← awk on ~/.zsh_functions (current state)
#
# For raw current state of Hyprland/tmux/vim binds, query the source directly:
#   hyprctl binds -j | jq          (Hyprland — needs interpretation)
#   grep -E '^(bind|set)' ~/.tmux.conf
#   grep -E '^(map|nnoremap)' ~/.vimrc

set -uo pipefail

DOCS_DIR="${CHEATSHEET_DIR:-$HOME/dotfiles/docs/cheatsheets}"

_walker_dmenu() {
    walker --dmenu --placeholder "$1" 2>/dev/null
}

# ─── Live sources ──────────────────────────────────────────────────────────
# Hyprland / tmux / vim previously had live grep-based sources here. They were
# removed when hyprland.md / tmux.md / vim.md became the canonical reference.
# For raw current state, run the underlying tool directly:
#   hyprctl binds -j | jq …          (Hyprland)
#   grep -E '^(bind|set)' ~/.tmux.conf  (tmux)
#   grep -E '^(map|nnoremap)' ~/.vimrc  (vim)

_src_zsh_aliases() {
    # Parse ~/.zshrc directly — `zsh -ic 'alias'` was ~200ms because it loads
    # all OMZ plugins + completions just to dump aliases. Trade-off: misses
    # plugin-generated aliases (git, etc.), but those usually have their own
    # man pages and aren't what the user wrote into the cheatsheet anyway.
    [[ -f "$HOME/.zshrc" ]] || return
    awk '/^[[:space:]]*alias / { sub(/^[[:space:]]*alias /, ""); print }' "$HOME/.zshrc" | sort
}

_src_zsh_functions() {
    [[ -f "$HOME/.zsh_functions" ]] || return
    awk '
        /^[[:space:]]*#/        { last_comment = $0; next }
        /^[a-zA-Z_][a-zA-Z0-9_-]*\(\)/ {
            name = $1; sub(/\(\).*/, "", name)
            printf "%-20s  %s\n", name, last_comment
            last_comment = ""
        }
    ' "$HOME/.zsh_functions"
}

_show_doc() {
    local file="$1" title="$2"
    # `floating-md` é classe própria — window rule em windowrules.lua dá
    # tamanho reading-friendly (mais estreito + alto).
    local class="floating-md"

    # Choice override: DOTS_MD_VIEWER=bat|glow|rich|auto (default: auto)
    #   glow → renderiza MD (headers stylized, tabelas reais, melhor leitura)
    #   bat  → mostra source com syntax highlighting (vê markup cru)
    #   rich → renderiza MD via python rich (paleta cyan/orange, AUR: rich-cli)
    local viewer="${DOTS_MD_VIEWER:-auto}"
    if [[ "$viewer" == "auto" ]]; then
        if   command -v glow >/dev/null; then viewer="glow"
        elif command -v rich >/dev/null; then viewer="rich"
        else                                  viewer="bat"
        fi
    fi

    local cmd
    case "$viewer" in
        glow)
            # Pipe glow → less -R em vez do pager interno do glow (-p): o
            # mini-pager do glow não tem busca funcional com ANSI codes;
            # less -R preserva cores E faz `/` busca propriamente.
            # less flags:
            #   -R          deixa ANSI escape codes passarem (cores do glow)
            #   -i          busca case-insensitive
            #   --mouse     scroll com mouse wheel
            #   --use-color colore o prompt do less
            cmd=(sh -c 'glow -s dark -w 90 "$1" | less -R -i --mouse --use-color' _ "$file")
            ;;
        bat)
            # MD com syntax highlighting (não renderiza headers etc, mostra source).
            # Bom pra ver markup cru + cores.
            cmd=(bat -l md --theme=base16 --paging=always
                 --wrap=auto --style=plain --color=always "$file")
            ;;
        rich)
            # rich-cli (AUR): renderização MD com paleta cyan/orange,
            # tabelas reais, code blocks com highlight. --pager usa less.
            cmd=(rich --markdown --pager --width 90 "$file")
            ;;
        *)
            dots-notification-send "Cheatsheet" "Viewer desconhecido: $viewer (use bat|glow|rich|auto)" -g "⚠"
            return 1
            ;;
    esac

    alacritty --class "$class" --title " $title" \
        -o font.size=12 \
        -o window.padding.x=20 -o window.padding.y=14 \
        -e "${cmd[@]}"
}

# ─── Inner menu: lines within category ─────────────────────────────────────

_browse() {
    local title="$1"
    local content; content="$(cat)"
    local pick
    pick="$(printf '← Back\n%s' "$content" | _walker_dmenu "$title:")"

    case "$pick" in
        ''|'← Back') return 10 ;;   # signal: back to main
        *)
            printf '%s' "$pick" | wl-copy
            dots-notification-send "Cheatsheet" "Copied" -g "" -t 2000
            ;;
    esac
}

# ─── Main menu ─────────────────────────────────────────────────────────────

_main_menu() {
    # Docs first — the polished .md cheatsheets are the canonical reference.
    # `hyprland.md`, `tmux.md`, `vim.md`, `zsh.md`, etc. all live in $DOCS_DIR.
    if [[ -d "$DOCS_DIR" ]]; then
        for f in "$DOCS_DIR"/*.md; do
            [[ -f "$f" ]] || continue
            printf '󰈙  %s\n' "$(basename "$f" .md)"
        done
    fi
    # Live sources — only kept where there's no static .md equivalent.
    # Aliases/functions change too often to be worth documenting statically;
    # show the current state from .zshrc / .zsh_functions instead.
    printf '󰒓  zsh aliases (live)\n'
    printf 'ƒ  shell functions (live)\n'
}

# ─── Main loop ─────────────────────────────────────────────────────────────

while :; do
    pick="$(_main_menu | _walker_dmenu 'Cheatsheet:')"
    [[ -z "$pick" ]] && exit 0

    # Branches match on the menu line's glyph prefix (unambiguous: each
    # category has a unique glyph). The doc branch then strips that exact
    # prefix to recover the filename — robust to doc names containing any
    # characters, including "  " which broke the previous `${pick##*  }`.
    case "$pick" in
        '󰒓  '*)  _src_zsh_aliases    | _browse "Zsh aliases" ;;
        'ƒ  '*)  _src_zsh_functions  | _browse "Shell functions" ;;
        '󰈙  '*)
            name="${pick#󰈙  }"
            file="$DOCS_DIR/$name.md"
            if [[ -f "$file" ]]; then
                _show_doc "$file" "$name"
                continue
            else
                dots-notification-send "Cheatsheet" "Not found: $name" -g "⚠"
            fi
            ;;
        *)
            dots-notification-send "Cheatsheet" "Unknown entry: $pick" -g "⚠"
            ;;
    esac
    rc=$?

    # _browse returns 10 on "← Back" → loop back to main menu.
    # Anything else (copy notification fired, user cancelled) → exit.
    [[ $rc -eq 10 ]] || exit 0
done
