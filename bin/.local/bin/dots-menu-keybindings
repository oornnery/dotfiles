#!/usr/bin/env bash
# dots:summary=Show Hyprland keybindings in a searchable walker menu (decoded mods + descriptions)
# dots:examples=dots-menu-keybindings

set -euo pipefail

# Hyprland modmask bitfield:
#   SHIFT=1, CAPS=2, CTRL=4, ALT=8, MOD2=16, MOD3=32, SUPER=64, MOD5=128
_decode_mods() {
    local m="$1" parts=()
    (( m & 64 ))  && parts+=("Super")
    (( m & 4 ))   && parts+=("Ctrl")
    (( m & 8 ))   && parts+=("Alt")
    (( m & 1 ))   && parts+=("Shift")
    if (( ${#parts[@]} == 0 )); then
        echo "—"
    else
        local IFS='+'
        echo "${parts[*]}"
    fi
}

# Parse all binds; format: "Super+Shift+H  →  description"
LINES=$(hyprctl binds -j 2>/dev/null \
    | jq -r '.[]
           | select(.key != "")
           | "\(.modmask // 0)|\(.key)|\(.description // .dispatcher) \(.arg // "")"' \
    | while IFS='|' read -r mods key rest; do
        printf "%-30s  →  %s\n" "$(_decode_mods "$mods")+$key" "$rest"
      done \
    | sort -u)

choice=$(printf '%s\n' "$LINES" | walker --dmenu --placeholder "Keybinds (digite pra filtrar):" 2>/dev/null)

[[ -n "$choice" ]] && {
    # Copia o bind selecionado pra clipboard
    printf '%s' "$choice" | wl-copy
    dots-notification-send "Bind copiado" "$choice" -g ""
}
