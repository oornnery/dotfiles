#!/usr/bin/env bash
# sudo-askpass — password helper for `sudo -A` / SUDO_ASKPASS.
#
# Sudo invokes this program (with the prompt string as $1) when it needs
# a password. The program writes the password to stdout. No pipe, no
# race conditions — sudo can call this again if the first attempt fails.
#
# Wire it up by setting SUDO_ASKPASS=$HOME/.local/bin/sudo-askpass and
# running `sudo -A …` (or alias sudo='sudo -A' in your shell rc).

set -uo pipefail

# Sudo passes its prompt as argv[1] (default "[sudo] password for $USER:").
prompt="${1:-Password:}"
prompt="${prompt%:}"           # strip trailing colon
prompt="${prompt#\[sudo\] }"   # strip leading "[sudo] "

if command -v gum >/dev/null 2>&1; then
    # Read from /dev/tty so we work even when sudo allocates a fresh TTY.
    gum input \
        --password \
        --header "󰣇 $prompt" \
        --prompt "󰌾 " \
        --width 60 \
        --header.foreground='212' \
        --prompt.foreground='212' </dev/tty
elif command -v zenity >/dev/null 2>&1; then
    zenity --password --title "$prompt"
else
    # Last resort: plain read from controlling terminal.
    read -rsp "$prompt: " p </dev/tty
    printf '\n' >&2
    printf '%s\n' "$p"
fi
