#!/usr/bin/env bash
# dots:summary=Walker power menu (lock/suspend/logout/reboot/shutdown)
# power-menu — fast walker-based power menu.
#
# Bound in hyprland/.config/hypr/lua/bindings.lua:
#   Super + Shift + P → power-menu

set -euo pipefail

if ! command -v walker >/dev/null; then
    notify-send -a power-menu -i dialog-error "power-menu" "walker not installed"
    exit 1
fi

_pick() {
    walker --dmenu --placeholder "$1" 2>/dev/null
}

choice="$(printf '%s\n' \
    "󰌾 Lock" \
    "󰤄 Suspend" \
    "󰍃 Logout" \
    "󰜉 Reboot" \
    "󰐥 Shutdown" \
    | _pick 'Power:'
)" || exit 0

case "$choice" in
    *Lock)    exec hyprlock ;;
    *Suspend) exec systemctl suspend ;;
    *Logout)  exec hyprctl dispatch exit ;;
    *Reboot)
        if [[ "$(printf 'Cancel\nReboot' | _pick 'Confirm reboot:')" == "Reboot" ]]; then
            exec systemctl reboot
        else
            notify-send -a power-menu -i dialog-information "Power" "Reboot cancelled" -t 1500
        fi
        ;;
    *Shutdown)
        if [[ "$(printf 'Cancel\nShutdown' | _pick 'Confirm shutdown:')" == "Shutdown" ]]; then
            exec systemctl poweroff
        else
            notify-send -a power-menu -i dialog-information "Power" "Shutdown cancelled" -t 1500
        fi
        ;;
esac
