#!/usr/bin/env bash
# dots:summary=Launch an app or focus an existing window matching pattern
# dots:args=<window-pattern> [launch-command]
# dots:examples=dots-launch-or-focus firefox | dots-launch-or-focus 'Visual Studio' code

set -euo pipefail

if (($# == 0)); then
    echo "Usage: dots-launch-or-focus <window-pattern> [launch-command]" >&2
    exit 1
fi

WINDOW_PATTERN="$1"
LAUNCH_COMMAND="${2:-$WINDOW_PATTERN}"

# Match by class OR title (word boundary, case-insensitive)
WINDOW_ADDRESS=$(hyprctl clients -j 2>/dev/null \
    | jq -r --arg p "$WINDOW_PATTERN" \
    '.[] | select((.class | test("\\b" + $p + "\\b"; "i"))
               or (.title | test("\\b" + $p + "\\b"; "i")))
          | .address' \
    | head -1)

if [[ -n "$WINDOW_ADDRESS" ]]; then
    hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS" >/dev/null
else
    setsid -f $LAUNCH_COMMAND >/dev/null 2>&1
fi
