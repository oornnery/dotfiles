#!/usr/bin/env bash
# dots:summary=Launch an app or focus an existing window matching pattern
# dots:args=<window-pattern> [launch-cmd [args...]]
# dots:examples=dots-launch-or-focus firefox | dots-launch-or-focus 'Visual Studio' code . | dots-launch-or-focus chromium chromium --user-data-dir=/path/with\ space

set -euo pipefail

if (($# == 0)); then
    echo "Usage: dots-launch-or-focus <window-pattern> [launch-cmd [args...]]" >&2
    exit 1
fi

WINDOW_PATTERN="$1"
shift
# Remaining args are the launch command + its arguments. If none given,
# fall back to using the pattern as the command (idiomatic for apps where
# the binary name matches the window class — firefox, code, etc.).
if (($# > 0)); then
    LAUNCH_CMD=("$@")
else
    LAUNCH_CMD=("$WINDOW_PATTERN")
fi

# Match by class OR title (word boundary, case-insensitive)
WINDOW_ADDRESS=$(hyprctl clients -j 2>/dev/null \
    | jq -r --arg p "$WINDOW_PATTERN" \
    '.[] | select((.class | test("\\b" + $p + "\\b"; "i"))
               or (.title | test("\\b" + $p + "\\b"; "i")))
          | .address' \
    | head -1)

if [[ -n "$WINDOW_ADDRESS" ]]; then
    hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS" >/dev/null
else
    setsid -f "${LAUNCH_CMD[@]}" >/dev/null 2>&1
fi
