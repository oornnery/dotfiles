#!/usr/bin/env bash
# dots — unified dotfiles CLI.
#
#   dots                     context-aware picker (walker in WM, fzf in terminal)
#   dots <group> [args…]     run ~/.local/lib/dots/<group> with args
#   dots help [topic]        cheatsheets (the `help` module)
#   dots commands            list group names
#   dots --help              this usage
#
# Modules live in ../lib/dots/ (one file per group) and compose by calling each
# other through `dots` (e.g. `dots notify`, `dots menu`). Metadata header per
# module: `# dots:summary=…`  `# dots:args=…`  `# dots:hidden=true`.

set -uo pipefail

# ─── Locate the module dir (sibling ../lib/dots, resolved through the symlink) ─
_self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
if [[ -n "${DOTS_LIBEXEC:-}" ]]; then
    LIBEXEC="$DOTS_LIBEXEC"
else
    _d="$(dirname "$_self")/../lib/dots"
    if [[ -d "$_d" ]]; then LIBEXEC="$(cd "$_d" && pwd)"; else LIBEXEC="$HOME/.local/lib/dots"; fi
fi
export DOTS_LIBEXEC="$LIBEXEC"
# Make sure `dots` itself is reachable for module re-dispatch.
export PATH="$(dirname "$_self"):$PATH"

# Short aliases: verb → module.
declare -A ALIASES=( [vol]=volume [shot]=screenshot [bright]=brightness )

_meta() {  # _meta <file> <key>  → value of `# dots:<key>=` from the header
    awk -v k="$2" '
        NR>40 { exit }
        /^# dots:/ {
            l = substr($0, 8); n = index(l, "=")
            if (n && substr(l, 1, n-1) == k) { print substr(l, n+1); exit }
        }' "$1" 2>/dev/null
}

_modules() { find "$LIBEXEC" -maxdepth 1 -type f -perm -u+x -printf '%f\n' 2>/dev/null | sort; }

_rows() {  # visible modules → "group<TAB>args<TAB>summary"
    local g f
    while IFS= read -r g; do
        [[ -z "$g" ]] && continue
        f="$LIBEXEC/$g"
        [[ "$(_meta "$f" hidden)" == "true" ]] && continue
        printf '%s\t%s\t%s\n' "$g" "$(_meta "$f" args)" "$(_meta "$f" summary)"
    done < <(_modules)
}

_usage() {
    printf '\033[1;32mdots\033[0m — dotfiles CLI\n\n'
    printf 'Usage:\n'
    printf '  dots                     open the picker\n'
    printf '  dots <group> [args…]     run a command\n'
    printf '  dots commands            list groups\n\n'
    printf 'Commands:\n'
    _rows | while IFS=$'\t' read -r g a s; do
        printf '  \033[1;32m%-16s\033[0m \033[2m%-24s\033[0m %s\n' "$g" "$a" "$s"
    done
}

_picker() {
    [[ -x "$LIBEXEC/menu" ]] || { _usage; return 0; }
    local sel
    sel="$(_rows | awk -F'\t' '{ printf "%-16s %s\n", $1, $3 }' | "$LIBEXEC/menu" "dots>")" || exit 0
    sel="${sel%% *}"
    [[ -n "$sel" && -x "$LIBEXEC/$sel" ]] || exit 0
    exec "$LIBEXEC/$sel"
}

_run() {
    local group="$1"; shift
    group="${ALIASES[$group]:-$group}"
    local mod="$LIBEXEC/$group"
    if [[ -x "$mod" ]]; then exec "$mod" "$@"; fi
    printf '\033[1;31merror:\033[0m unknown command: %s\n' "$group" >&2
    printf 'Run "dots --help" to list commands.\n' >&2
    exit 127
}

case "${1:-}" in
    '')             _picker ;;
    -h|--help)      _usage ;;
    commands)       _rows | cut -f1 ;;
    *)              _run "$@" ;;
esac
