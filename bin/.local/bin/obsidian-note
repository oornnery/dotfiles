#!/usr/bin/env bash
# obsidian-note — wofi + CLI helper for an Obsidian vault.
#
# Subcommands:
#   obsidian-note new "Title"   create a new note with frontmatter
#   obsidian-note today         open today's daily note (creates if missing)
#   obsidian-note find          wofi fuzzy-pick by filename → open in $EDITOR
#   obsidian-note search [Q]    ripgrep across the vault → wofi pick line → open
#   obsidian-note open <file>   open <file> in $EDITOR
#   obsidian-note obsidian      wofi pick → open in Obsidian GUI (obsidian:// URI)
#
# Vault: $OBSIDIAN_VAULT (default ~/Documents/vault). Daily notes go to
# $VAULT/Daily/YYYY-MM-DD.md.

set -uo pipefail

VAULT="${OBSIDIAN_VAULT:-$HOME/Documents/vault}"
DAILY="$VAULT/Daily"
EDITOR="${EDITOR:-nvim}"

mkdir -p "$VAULT" "$DAILY"

_open_editor() {
    local file="$1" line="${2:-1}"
    if [[ -n "${TMUX:-}" ]] || [[ -t 1 ]]; then
        # Already in a terminal — open directly.
        "$EDITOR" "+$line" "$file"
    else
        # Launched from wofi / Hyprland — pop a floating terminal.
        setsid -f alacritty --class floating -e "$EDITOR" "+$line" "$file" \
            >/dev/null 2>&1 &
    fi
}

_open_obsidian() {
    local file="$1"
    local rel="${file#"$VAULT"/}"
    local vault_name; vault_name="$(basename "$VAULT")"
    # URL-encode minimally (spaces, slashes are fine for obsidian://)
    local enc; enc="$(printf '%s' "${rel%.md}" | sed 's/ /%20/g')"
    xdg-open "obsidian://open?vault=$vault_name&file=$enc" >/dev/null 2>&1 &
}

case "${1:-help}" in
    new)
        shift
        title="${*:?Usage: obsidian-note new <title>}"
        ts="$(date +%Y-%m-%d)"
        slug="$(printf '%s' "$title" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')"
        file="$VAULT/$ts-$slug.md"
        if [[ -e "$file" ]]; then
            notify-send -a obsidian-note "Note exists" "$file"
        else
            cat > "$file" <<EOF
---
title: $title
date: $ts
tags: []
---

# $title

EOF
            notify-send -a obsidian-note "Note created" "$file"
        fi
        _open_editor "$file"
        ;;

    today|daily)
        ts="$(date +%Y-%m-%d)"
        file="$DAILY/$ts.md"
        if [[ ! -f "$file" ]]; then
            cat > "$file" <<EOF
---
date: $ts
day: $(date +%A)
tags: [daily]
---

# $(date '+%A, %B %d, %Y')

## Notes

## Tasks

- [ ]

## Links

EOF
        fi
        _open_editor "$file"
        ;;

    find)
        pick="$(
            find "$VAULT" -name '*.md' -type f -printf '%P\n' 2>/dev/null \
                | sort \
                | wofi --dmenu --prompt 'Note:' --width 720 --insensitive
        )" || exit 0
        [[ -z "$pick" ]] && exit 0
        _open_editor "$VAULT/$pick"
        ;;

    search)
        shift || true
        query="${*:-}"
        if [[ -z "$query" ]]; then
            query="$(printf '' | wofi --dmenu --prompt 'Search vault:' --lines 1)" || exit 0
        fi
        [[ -z "$query" ]] && exit 0
        result="$(
            rg --color=never --line-number --no-heading "$query" "$VAULT" --type md 2>/dev/null \
                | sed -E "s|^$VAULT/||" \
                | wofi --dmenu --prompt 'Match:' --width 1000 --insensitive
        )" || exit 0
        [[ -z "$result" ]] && exit 0
        file="${result%%:*}"
        line="$(printf '%s' "$result" | cut -d: -f2)"
        _open_editor "$VAULT/$file" "$line"
        ;;

    open)
        _open_editor "${2:?Usage: obsidian-note open <file>}"
        ;;

    obsidian|gui)
        pick="$(
            find "$VAULT" -name '*.md' -type f -printf '%P\n' 2>/dev/null \
                | sort \
                | wofi --dmenu --prompt 'Open in Obsidian:' --width 720 --insensitive
        )" || exit 0
        [[ -z "$pick" ]] && exit 0
        _open_obsidian "$VAULT/$pick"
        ;;

    -h|--help|help)
        sed -n '2,15p' "$0"
        ;;

    *)
        echo "obsidian-note: unknown command: $1" >&2
        echo "Try: obsidian-note --help" >&2
        exit 1
        ;;
esac
