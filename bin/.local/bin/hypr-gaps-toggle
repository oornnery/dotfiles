#!/usr/bin/env bash
# dots:summary=Toggle Hyprland gaps + borders + rounding
# hypr-gaps-toggle — liga/desliga gaps + bordas (modo fullscreen-ish).
# Estado armazenado em $XDG_RUNTIME_DIR/hypr-gaps-state.

set -euo pipefail

STATE="${XDG_RUNTIME_DIR:-/tmp}/hypr-gaps-state"

if [[ -f "$STATE" ]]; then
    # Restore defaults
    rm -f "$STATE"
    hyprctl --batch "\
        keyword general:gaps_in 4; \
        keyword general:gaps_out 8; \
        keyword general:border_size 2; \
        keyword decoration:rounding 8" >/dev/null
    notify-send -a hypr-gaps "Gaps" "ON (default)"
else
    # No-gaps mode
    touch "$STATE"
    hyprctl --batch "\
        keyword general:gaps_in 0; \
        keyword general:gaps_out 0; \
        keyword general:border_size 0; \
        keyword decoration:rounding 0" >/dev/null
    notify-send -a hypr-gaps "Gaps" "OFF (zero)"
fi
