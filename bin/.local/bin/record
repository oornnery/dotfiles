#!/usr/bin/env bash
# record — toggle screen recording via wf-recorder.
#
# Usage:
#   record              toggle: start full-screen / stop running
#   record region       start recording a region
#   record stop         stop any active recording
#   record status       running? print PID + file

set -euo pipefail

OUT_DIR="${RECORD_DIR:-$HOME/Videos/recordings}"
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/wf-recorder.pid"
mkdir -p "$OUT_DIR"

if ! command -v wf-recorder >/dev/null; then
    notify-send -a record -i dialog-error "Record" "wf-recorder not installed"
    exit 1
fi

_active_pid() {
    [[ -f "$PID_FILE" ]] || return 1
    local pid; pid="$(cat "$PID_FILE")"
    kill -0 "$pid" 2>/dev/null || { rm -f "$PID_FILE"; return 1; }
    echo "$pid"
}

_start() {
    local file
    file="$OUT_DIR/$(date +%Y%m%d-%H%M%S).mp4"
    local geo="${1:-}"
    if [[ -n "$geo" ]]; then
        wf-recorder -g "$geo" -f "$file" &
    else
        wf-recorder -f "$file" &
    fi
    echo $! > "$PID_FILE"
    notify-send -a record -i media-record -t 2500 "Recording" "$file"
}

_stop() {
    local pid
    if pid="$(_active_pid)"; then
        kill -INT "$pid"
        wait "$pid" 2>/dev/null || true
        rm -f "$PID_FILE"
        notify-send -a record -i media-playback-stop -t 2500 "Stopped" "Saved in $OUT_DIR"
    else
        notify-send -a record -t 2000 "Record" "nothing was recording"
    fi
}

case "${1:-toggle}" in
    toggle|"")
        if _active_pid >/dev/null; then _stop; else _start; fi
        ;;
    region)
        _active_pid >/dev/null && _stop
        _start "$(slurp)"
        ;;
    stop)   _stop ;;
    status)
        if pid="$(_active_pid)"; then
            echo "Recording (pid $pid)"
        else
            echo "Not recording"
        fi
        ;;
    -h|--help|help) sed -n '2,8p' "$0" ;;
    *) echo "record: unknown command: $1" >&2; exit 1 ;;
esac
