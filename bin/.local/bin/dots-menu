#!/usr/bin/env bash
# dots:summary=Universal menu picker via walker dmenu mode
# dots:args=<title> < lines_from_stdin
# dots:examples=printf 'A\nB\nC\n' | dots-menu "Choose" | head -1

set -euo pipefail

title="${1:-Pick}"

# walker --dmenu reads stdin lines and prints selected
walker --dmenu --placeholder "$title" 2>/dev/null
