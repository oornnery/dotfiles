#!/usr/bin/env bash
# scratch — quake-style scratchpad terminal toggle.
#
# Uses Hyprland's "special:scratch" workspace. First invocation
# creates an alacritty there and brings it forward. Subsequent
# invocations toggle visibility.

set -euo pipefail

WS="special:scratch"
CLASS="scratch"

# Already exists?
if hyprctl clients -j | jq -e --arg c "$CLASS" '.[] | select(.class == $c)' >/dev/null; then
    hyprctl dispatch togglespecialworkspace scratch >/dev/null
else
    hyprctl dispatch exec "[workspace $WS silent;float;size 80% 60%;center] alacritty --class $CLASS" >/dev/null
    sleep 0.15
    hyprctl dispatch togglespecialworkspace scratch >/dev/null
fi
