#!/usr/bin/env bash
# dots:summary=Toggle Hyprland window corner rounding (sharp/round)
# dots:args=<sharp|round>
# dots:hidden=true

set -euo pipefail

mode="$1"
case "$mode" in
    sharp) hyprctl keyword decoration:rounding 0 >/dev/null ;;
    round) hyprctl keyword decoration:rounding 8 >/dev/null ;;
esac
