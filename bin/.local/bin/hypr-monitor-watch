#!/usr/bin/env bash
# dots:summary=Auto re-apply monitor config on plug/unplug
# hypr-monitor-watch — escuta eventos Hyprland e re-aplica layout quando
# monitor é plugado/desplugado. Rodar via exec-once (autostart.lua).
#
# Trigger atualiza monitor.conf semantics via hyprctl reload (que re-lê
# lua/monitors.lua). Útil em laptops + KVM + dock changes.

set -euo pipefail

SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"

if [[ ! -S "$SOCKET" ]]; then
    echo "hypr-monitor-watch: socket não encontrado em $SOCKET" >&2
    exit 1
fi

socat -U - "UNIX-CONNECT:$SOCKET" 2>/dev/null | while read -r line; do
    case "$line" in
        monitoradded*|monitorremoved*|monitoraddedv2*)
            # Pequeno delay para o monitor estabilizar antes de reload.
            sleep 0.5
            hyprctl reload >/dev/null 2>&1 || true
            ;;
    esac
done
