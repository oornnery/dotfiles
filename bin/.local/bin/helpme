#!/usr/bin/env bash
# dots:summary=Essential tmux and Vim/Neovim shortcut guide
# dots:args=[tmux|vim|nvim|all]

set -euo pipefail

pager=1
if [[ "${1:-}" == "--no-pager" ]]; then
    pager=0
    shift
fi

topic="${1:-all}"

usage() {
    cat <<'EOF'
Usage:
  helpme [tmux|vim|nvim|all]
  helpme --no-pager [tmux|vim|nvim|all]

Inside Vim/Neovim:
  :Helpme
  :Cheatsheet
  :Helpme tmux
  <leader>?

Inside tmux:
  C-a /              open the tmux cheatsheet popup
  C-a F1             open the full cheatsheet popup

Search inside the pager:
  /text              search forward
  n / N              next / previous result
  q                  close
EOF
}

tmux_sheet() {
    cat <<'EOF'
# Tmux Essentials

## Prefix
  C-a                prefix key
  C-a ?              open this tmux cheatsheet popup
  C-a /              open this tmux cheatsheet popup
  C-a F1             open the full cheatsheet popup
  C-a r              reload ~/.tmux.conf

## Panes
  C-a |              split right in current directory
  C-a -              split down in current directory
  C-a h/j/k/l        move between panes
  M-h/j/k/l          move between panes without prefix
  C-a H/J/K/L        resize pane
  M-Arrows           resize pane without prefix
  C-a z              zoom/unzoom pane
  C-a q              show pane numbers
  C-a x              kill pane, with confirmation

## Windows
  C-a c              new window in current directory
  C-a n / C-a p      next / previous window
  C-a Tab            last window
  M-1..M-0           jump to windows 1..10
  C-a ,              rename window
  C-a X              kill window, with confirmation

## Sessions
  C-a s              session tree
  C-a w              window tree
  C-a N              new named session
  C-a $              rename session
  C-a L              last session
  C-a Q              kill session, with confirmation

## Layouts
  C-a Space          next layout
  C-a =              even horizontal
  C-a +              even vertical
  C-a m              main vertical
  C-a M              main horizontal
  C-a t              tiled

## Copy Mode
  C-a [              enter copy mode
  h/j/k/l            move
  / or ?             search down / up
  n / N              next / previous search match
  v                  start selection
  V                  select line
  C-v                rectangle selection
  y or Enter         copy selection
  C-a ]              paste tmux buffer
  C-a P              choose buffer

## Useful Extras
  C-a a              toggle synchronize-panes
  C-a f              find text in open panes/windows
  C-a T              popup shell in current directory

## Statusline Mode Block
  INSERT             zsh vi insert mode
  NORMAL             zsh vi normal mode
  VISUAL             zsh vi visual mode
  REPLACE            zsh vi replace mode
  PREFIX             you pressed C-a and tmux is waiting for a key
  COPY               current pane is in copy mode
  SYNC               synchronize-panes is enabled
EOF
}

vim_core_sheet() {
    cat <<'EOF'
# Vim / Neovim Core

## Modes
  i                  insert before cursor
  a                  insert after cursor
  o / O              new line below / above
  Esc                normal mode
  v / V / C-v        visual char / line / block
  :                  command line

## Save / Quit
  :w                 save
  :q                 quit
  :wq or :x          save and quit
  :q!                quit without saving

## Move
  h/j/k/l            left / down / up / right
  w / b / e          next word / previous word / end word
  0 / ^ / $          line start / first nonblank / line end
  gg / G             top / bottom of file
  { / }              previous / next paragraph
  C-d / C-u          half page down / up

## Edit
  x                  delete char
  dd / yy / p        delete line / yank line / paste
  ciw / diw / yiw    change / delete / yank inner word
  u / C-r            undo / redo
  .                  repeat last change
  > / < in visual    indent right / left and keep selection

## Search
  /text              search forward
  ?text              search backward
  n / N              next / previous match
  * / #              search word under cursor forward / backward
  Esc Esc            clear search highlight in these dotfiles

## Windows
  C-w v / C-w s      vertical / horizontal split
  C-w h/j/k/l        move between windows
  C-w =              equalize split sizes
  C-w q              close current window

## Built-in Help
  :help motion.txt   help for movement
  :help usr_02.txt   first steps
  :help index        giant key index
EOF
}

vim_dotfiles_sheet() {
    cat <<'EOF'

# Dotfiles Vim Mappings

## Leader
  Space              leader in vim/.vimrc and native Nvim
  ,                  leader in the old vim.plug profile only

## Files / Project
  <leader>w          write file
  <leader>q          quit window
  <leader>x          write and quit
  <leader>e          file explorer on the side
  <leader>E          file explorer in current window
  <leader>ff         find file with native :find
  <leader>sg         search project with native :vimgrep

## Buffers / Quickfix
  <leader>bb         list buffers, then type a buffer number/name
  <leader>bd         delete buffer
  [b / ]b            previous / next buffer
  [q / ]q            previous / next quickfix item
  <leader>co         open quickfix
  <leader>cc         close quickfix

## Splits / Editing
  C-h/j/k/l          move between splits
  <leader>sv         vertical split
  <leader>sh         horizontal split
  <leader>=          equalize splits
  gcc                comment/uncomment current line
  gc in visual       comment/uncomment selection
  <leader>f          reindent file or visual selection
  <leader>tw         toggle wrap
  <leader>ts         toggle spell
  <leader>tt         terminal split

## Cheatsheet
  :Helpme            open Vim helper
  :Cheatsheet        open Vim helper
  :Helpme tmux       open tmux helper
  <leader>?          open helper in Vim/Neovim
EOF
}

nvim_dotfiles_sheet() {
    cat <<'EOF'

# Dotfiles Neovim Mappings

## Native Nvim Profile
  <leader>w/q/x      write / quit / write and quit
  <leader>e/E        netrw explorer side/current
  <leader>ff         native :find
  <leader>sg         native project search
  <leader>rr         cd to project root
  <leader>bb/bd      switch / delete buffer
  [b / ]b            previous / next buffer
  <leader>sv/sh/=    vertical split / horizontal split / equalize
  gcc / visual gc    comment line / selection
  <leader>tt         terminal split
  Esc Esc            leave terminal mode or clear search
  <leader>?          open this helper

## Mini Profile Highlights
  <leader>ff         file picker
  <leader>fg         live grep
  <leader>fb         buffer picker
  <leader>fh         help picker
  <leader>ed/ef      open directory / file directory
  <leader>bd         delete buffer
  <leader>ld/lh/lr   diagnostic popup / hover / rename
  <leader>lf         format
  <leader>tt/tT      terminal vertical / horizontal

## LazyVim Profile Highlights
  Space              opens the which-key guide
  <leader>ff         find files
  <leader>/          grep/search
  <leader>e          explorer
  <leader>gg         LazyGit, when installed
  gd / gr / K        definition / references / hover
  <leader>ca         code actions
  <leader>cr         rename
  <leader>ha/hh      Harpoon add / menu
  <leader>1..4       Harpoon jump slots

## Cheatsheet
  :Helpme            open Nvim helper
  :Cheatsheet        open Nvim helper
  :Helpme vim        open Vim helper
  :Helpme tmux       open tmux helper
  <leader>?          open helper in Vim/Neovim
EOF
}

print_topic() {
    case "$1" in
        tmux)
            tmux_sheet
            ;;
        vim)
            vim_core_sheet
            vim_dotfiles_sheet
            ;;
        nvim)
            vim_core_sheet
            nvim_dotfiles_sheet
            ;;
        all)
            tmux_sheet
            printf '\n'
            vim_core_sheet
            vim_dotfiles_sheet
            nvim_dotfiles_sheet
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            printf 'Unknown topic: %s\n\n' "$1" >&2
            usage >&2
            exit 2
            ;;
    esac
}

run_glow() {
    local config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
    local fallback_home="${XDG_RUNTIME_DIR:-/tmp}/dotfiles-glow"

    if [[ ! -d "$config_home/glow" && ! -w "$config_home" ]]; then
        mkdir -p "$fallback_home"
        export XDG_CONFIG_HOME="$fallback_home"
    fi

    if command -v less >/dev/null 2>&1; then
        local less_opts="${LESS:-RX}"
        less_opts="${less_opts//F/}"
        glow --style dark --width "${COLUMNS:-120}" - | LESS="$less_opts" less -R -i --mouse --use-color
    else
        glow --pager -
    fi
}

if [[ "$pager" -eq 1 && -t 1 ]] && command -v glow >/dev/null 2>&1; then
    print_topic "$topic" | run_glow
elif [[ "$pager" -eq 1 && -t 1 ]] && command -v less >/dev/null 2>&1; then
    print_topic "$topic" | less -R
else
    print_topic "$topic"
fi
