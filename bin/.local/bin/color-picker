#!/usr/bin/env bash
# dots:summary=Pick color from screen (hyprpicker) → clipboard + history
# color-picker — hyprpicker wrapper that copies hex + notifies + appends history.

set -euo pipefail

HIST="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/color-history"
mkdir -p "$(dirname "$HIST")"

if ! command -v hyprpicker >/dev/null; then
    notify-send -a color-picker -i dialog-error \
        "Color picker" "hyprpicker not installed"
    exit 1
fi

hex="$(hyprpicker -f hex -a 2>/dev/null || true)"
[[ -z "$hex" ]] && exit 0

# wl-copy is done by hyprpicker -a already; record to history.
printf '%s  %s\n' "$(date +%H:%M:%S)" "$hex" >> "$HIST"

notify-send -a color-picker -i color-picker -t 3000 \
    "Color copied" "$hex" \
    --hint=string:image-path:"$HOME/.cache/color-picker-swatch.png" \
    || true
