#!/usr/bin/env bash
# update — system + ecosystem updater.
#
# Usage:
#   update                  apply all updates (snapshot first)
#   update run              alias for default
#   update check            JSON output for waybar/cron (counts only)
#   update list             human-readable list of available updates
#
# Ecosystems checked: pacman, AUR (paru), flatpak, npm -g, cargo (cargo-update),
# pipx, uv. Each step is best-effort and skipped silently if the tool is absent.

set -uo pipefail

CACHE="${XDG_RUNTIME_DIR:-/tmp}/update-check.json"

_have() { command -v "$1" >/dev/null 2>&1; }

# ─── Counters ──────────────────────────────────────────────────────────────

_count_pacman()  { _have checkupdates && checkupdates 2>/dev/null | wc -l || echo 0; }
_count_aur()     { _have paru && paru -Qua 2>/dev/null | wc -l || echo 0; }
_count_flatpak() { _have flatpak && flatpak remote-ls --updates 2>/dev/null | wc -l || echo 0; }
_count_npm()     { _have npm && npm outdated -g --parseable 2>/dev/null | wc -l || echo 0; }
_count_cargo()   { _have cargo-install-update && cargo install-update -l 2>/dev/null | grep -c '^Yes ' || echo 0; }
_count_pipx()    { _have pipx && pipx list --json 2>/dev/null | jq -r '.venvs | keys | length' 2>/dev/null || echo 0; }
_count_uv()      { _have uv && uv tool list 2>/dev/null | grep -c '^' || echo 0; }

# ─── Subcommands ──────────────────────────────────────────────────────────

_check() {
    local p a f n c x u total
    p=$(_count_pacman) a=$(_count_aur) f=$(_count_flatpak)
    n=$(_count_npm)    c=$(_count_cargo) x=$(_count_pipx) u=$(_count_uv)
    total=$(( p + a + f + n + c ))
    cat <<EOF
{
  "count": $total,
  "pacman": $p,
  "aur": $a,
  "flatpak": $f,
  "npm": $n,
  "cargo": $c,
  "pipx": $x,
  "uv": $u,
  "text": "$total",
  "tooltip": "pacman: $p, AUR: $a, flatpak: $f, npm: $n, cargo: $c, pipx: $x, uv: $u",
  "class": "$([ "$total" -gt 0 ] && echo updates || echo clean)"
}
EOF
}

_list() {
    _have checkupdates && { echo "── pacman ──"; checkupdates 2>/dev/null | sed 's/^/  /'; echo; }
    _have paru         && { echo "── AUR ──";    paru -Qua    2>/dev/null | sed 's/^/  /'; echo; }
    _have flatpak      && { echo "── flatpak ──"; flatpak remote-ls --updates 2>/dev/null | sed 's/^/  /'; echo; }
    _have npm          && { echo "── npm -g ──"; npm outdated -g --parseable 2>/dev/null | sed 's/^/  /'; echo; }
    _have cargo-install-update && { echo "── cargo ──"; cargo install-update -l 2>/dev/null | sed 's/^/  /'; echo; }
}

_run() {
    local user="${SUDO_USER:-$USER}"
    local _as_user
    if [[ $EUID -eq 0 && "$user" != "root" ]]; then
        _as_user=(sudo -u "$user" -H)
    else
        _as_user=()
    fi21

    # 1. Pre-update btrfs snapshot if snapper is present + root is btrfs.
    if _have snapper && findmnt -no FSTYPE / 2>/dev/null | grep -qx btrfs; then
        printf '\n── snapper snapshot ──\n'
        sudo snapper -c root create -t single -d "pre-update $(date +%F)" \
            || echo "  (snapper failed — continuing anyway)"
    fi

    # 2. pacman + AUR
    if _have paru; then
        printf '\n── paru -Syu ──\n'
        "${_as_user[@]}" paru -Syu
    elif _have pacman; then
        printf '\n── pacman -Syu ──\n'
        sudo pacman -Syu
    fi

    # 3. flatpak
    if _have flatpak; then
        printf '\n── flatpak update ──\n'
        flatpak update -y || true
    fi

    # 4. npm globals
    if _have npm; then
        printf '\n── npm -g ──\n'
        "${_as_user[@]}" npm update -g || true
    fi

    # 5. cargo install-update (needs `cargo install cargo-update` once)
    if _have cargo-install-update; then
        printf '\n── cargo install-update ──\n'
        "${_as_user[@]}" cargo install-update -a || true
    fi

    # 6. pipx
    if _have pipx; then
        printf '\n── pipx upgrade-all ──\n'
        "${_as_user[@]}" pipx upgrade-all || true
    fi

    # 7. uv tools
    if _have uv; then
        printf '\n── uv tool upgrade ──\n'
        "${_as_user[@]}" uv tool upgrade --all || true
    fi

    # 8. Refresh cached JSON.
    _check > "$CACHE" || true

    notify-send -a update -i system-software-update -t 5000 \
        "Update complete" "All ecosystems refreshed"
}

case "${1:-run}" in
    ""|run) _run ;;
    check)  _check ;;
    list)   _list ;;
    -h|--help|help) sed -n '2,11p' "$0" ;;
    *)      echo "update: unknown command: $1" >&2; exit 1 ;;
esac
