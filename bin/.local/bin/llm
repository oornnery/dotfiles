#!/usr/bin/env bash
# dots:summary=Pick an LLM CLI (claude/codex/…) and open in a floating terminal
# dots:examples=llm | llm claude | llm codex
#
# Walker picker over detected LLM CLIs → spawns `floating-tui <cli>` so the
# session lives in a centred alacritty window. Bound to Super+I.

set -euo pipefail

# Discover which LLM CLIs are installed on PATH. Add more here as you adopt
# new tools (gemini, llm, aichat, etc.).
declare -A LLMS=(
    [claude]="Claude Code (Anthropic)"
    [codex]="Codex (OpenAI)"
    [gemini]="Gemini CLI (Google)"
    [aichat]="aichat (multi-model)"
    [llm]="Simon Willison's llm CLI"
    [ollama]="ollama (local models)"
)

_available() {
    for cli in "${!LLMS[@]}"; do
        if command -v "$cli" >/dev/null 2>&1; then
            printf '%s\t%s\n' "$cli" "${LLMS[$cli]}"
        fi
    done | sort
}

# If invoked with an arg, launch that LLM directly (skip picker).
if [[ $# -gt 0 ]]; then
    if ! command -v "$1" >/dev/null 2>&1; then
        notify-send -a llm -u critical "LLM" "Not installed: $1"
        exit 1
    fi
    exec floating-tui "$@"
fi

# Pick via walker.
available="$(_available)"
if [[ -z "$available" ]]; then
    notify-send -a llm -u critical "LLM" "No LLM CLI detected. Install one of: ${!LLMS[*]}"
    exit 1
fi

pick="$(printf '%s' "$available" | walker --dmenu --placeholder 'LLM:' 2>/dev/null)" || exit 0
[[ -z "$pick" ]] && exit 0

cli="${pick%%$'\t'*}"
command -v floating-tui >/dev/null || { notify-send -a llm "LLM" "floating-tui missing"; exit 1; }
exec floating-tui "$cli"
