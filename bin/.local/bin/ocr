#!/usr/bin/env bash
# dots:summary=OCR screen region (grim + tesseract → clipboard)
# ocr — capture screen region, OCR via tesseract, copy text to clipboard.
#
# Usage:
#   ocr             region → text → clipboard (default eng+por)
#   ocr eng         force English only
#   ocr por         force Portuguese only

set -euo pipefail

if ! command -v tesseract >/dev/null; then
    notify-send -a ocr -i dialog-error "OCR" "tesseract not installed"
    exit 1
fi

lang="${1:-eng+por}"
tmp="$(mktemp --suffix=.png)"
trap 'rm -f "$tmp" "${tmp%.png}.txt"' EXIT

grim -g "$(slurp)" "$tmp" 2>/dev/null || exit 0

# tesseract appends .txt to the output base name.
out_base="${tmp%.png}"
tesseract "$tmp" "$out_base" -l "$lang" 2>/dev/null

text="$(cat "${out_base}.txt")"
if [[ -z "${text// /}" ]]; then
    notify-send -a ocr -i dialog-warning "OCR" "no text detected"
    exit 0
fi

printf '%s' "$text" | wl-copy
preview="${text:0:200}"
notify-send -a ocr -i edit-copy -t 4000 "OCR copied" "${preview}${text:200:+…}"
