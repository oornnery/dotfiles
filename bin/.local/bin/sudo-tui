#!/usr/bin/env bash
# sudo-tui — sudo wrapper that uses gum (via SUDO_ASKPASS) for password
# input. Calls sudo -A under the hood so sudo handles its own retry
# loop properly (no pipe consumption issue).
#
# Usage:  sudo-tui pacman -Syu
#         sudo-tui -i        # interactive root shell
#         sudo-tui -k        # invalidate sudo cache
#
# Tip: in your shell rc, `alias sudo='sudo -A'` after exporting
# SUDO_ASKPASS gives every `sudo` invocation the TUI prompt.

set -euo pipefail

ASKPASS="${SUDO_ASKPASS:-$HOME/.local/bin/sudo-askpass}"

if [[ ! -x "$ASKPASS" ]]; then
    echo "sudo-tui: $ASKPASS not executable" >&2
    echo "          chmod +x $ASKPASS" >&2
    exit 1
fi
export SUDO_ASKPASS="$ASKPASS"

# Warn if PAM faillock recorded recent failures (the cause of
# "Sorry, try again" after canceled sudo prompts).
if command -v faillock >/dev/null 2>&1; then
    fails="$(faillock --user "${USER:-$LOGNAME}" 2>/dev/null \
        | awk '/^When/ {found=1; next} found && NF {n++} END {print n+0}')"
    if (( fails >= 2 )); then
        printf 'sudo-tui: %d recent sudo failure(s) recorded for %s\n' \
            "$fails" "${USER:-$LOGNAME}" >&2
        printf '          if locked out: sudo faillock --user %s --reset\n' \
            "${USER:-$LOGNAME}" >&2
    fi
fi

exec sudo -A "$@"
