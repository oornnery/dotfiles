#!/usr/bin/env bash
# floating-tui — open a TUI in a floating alacritty window.
#
# Usage:
#   floating-tui lazygit
#   floating-tui btop
#
# Bound in hyprland/bindings.conf for lazygit/lazydocker/btop/bluetui/
# impala/cliamp.

set -euo pipefail

cmd="${1:-}"
[[ -z "$cmd" ]] && { echo "Usage: floating-tui <command>" >&2; exit 1; }

if ! command -v "$cmd" >/dev/null; then
    notify-send -a floating-tui -i dialog-error \
        "floating-tui" "$cmd not found"
    exit 1
fi

shift || true
exec alacritty --class floating-tui -e "$cmd" "$@"
