#!/usr/bin/env bash
# dots:summary=Manage hyprpaper wallpaper (next/prev/random/set/get)
# wallpaper — manage Hyprland wallpapers via hyprpaper.
#
# Usage:
#   wallpaper                  show current
#   wallpaper next             next file in $WALLPAPER_DIR
#   wallpaper prev             previous
#   wallpaper random           random
#   wallpaper set <path>       set explicit
#
# Wallpapers live in ~/Pictures/wallpapers/ (override with $WALLPAPER_DIR).
# State in ~/.local/share/dotfiles/active-wallpaper.

set -euo pipefail

DIR="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"
STATE="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/active-wallpaper"
mkdir -p "$(dirname "$STATE")" "$DIR"

_list() {
    find "$DIR" -maxdepth 2 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) \
        | sort
}

_current() {
    [[ -f "$STATE" ]] && cat "$STATE" || echo ""
}

_apply() {
    local path="$1"
    [[ -f "$path" ]] || { echo "wallpaper: file not found: $path" >&2; exit 1; }
    hyprctl hyprpaper preload "$path" >/dev/null
    # Set on all monitors.
    while IFS= read -r mon; do
        hyprctl hyprpaper wallpaper "$mon,$path" >/dev/null
    done < <(hyprctl monitors -j | jq -r '.[].name')
    # Unload any previously preloaded (saves memory).
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$path" >/dev/null
    echo "$path" > "$STATE"
    notify-send -a wallpaper -i "$path" -t 3000 \
        "Wallpaper" "$(basename "$path")"
}

cmd="${1:-get}"; shift || true

case "$cmd" in
    ""|get)
        _current
        ;;
    list)
        _list
        ;;
    next|prev)
        mapfile -t files < <(_list)
        (( ${#files[@]} == 0 )) && { echo "wallpaper: no images in $DIR" >&2; exit 1; }
        cur="$(_current)"
        idx=0
        for i in "${!files[@]}"; do
            [[ "${files[i]}" == "$cur" ]] && { idx=$i; break; }
        done
        if [[ "$cmd" == "next" ]]; then
            idx=$(( (idx + 1) % ${#files[@]} ))
        else
            idx=$(( (idx - 1 + ${#files[@]}) % ${#files[@]} ))
        fi
        _apply "${files[idx]}"
        ;;
    random)
        mapfile -t files < <(_list)
        (( ${#files[@]} == 0 )) && { echo "wallpaper: no images in $DIR" >&2; exit 1; }
        _apply "${files[$RANDOM % ${#files[@]}]}"
        ;;
    set)
        [[ -z "${1:-}" ]] && { echo "Usage: wallpaper set <path>" >&2; exit 1; }
        _apply "$1"
        ;;
    -h|--help|help)
        sed -n '2,11p' "$0"
        ;;
    *)
        echo "wallpaper: unknown command: $cmd" >&2
        exit 1
        ;;
esac
