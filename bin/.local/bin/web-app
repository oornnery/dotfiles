#!/usr/bin/env bash
# dots:summary=Launch Firefox PWA web app by name
# web-app — thin wrapper around firefoxpwa for installing/launching site PWAs.
#
# Usage:
#   web-app install <url> <name>        install a site as a standalone PWA
#   web-app launch  <name>              launch a previously installed PWA
#   web-app list                        list installed PWAs
#   web-app remove  <name>              uninstall a PWA
#
# Hyprland binds (see hyprland/bindings.conf):
#   Super+Shift+G  →  web-app launch chatgpt
#   Super+Shift+W  →  web-app launch whatsapp
#   …

set -euo pipefail

if ! command -v firefoxpwa >/dev/null; then
    echo "web-app: firefoxpwa not installed." >&2
    echo "         Run: paru -S firefoxpwa  (or: scripts/arch/core/firefoxpwa.sh)" >&2
    exit 1
fi

_id_of() {
    # Resolve a friendly name → firefoxpwa ulid.
    firefoxpwa profile list 2>/dev/null \
        | awk -v name="$1" '
            /^- / { id=$2 }
            $0 ~ "Name: " name "$" { print id; exit }
        '
}

case "${1:-help}" in
    install)
        url="${2:-}"; name="${3:-}"
        if [[ -z "$url" || -z "$name" ]]; then
            echo "Usage: web-app install <url> <name>" >&2
            exit 1
        fi
        firefoxpwa site install "$url" --name "$name"
        echo "Installed: $name → $url"
        echo "Launch with: web-app launch $name"
        ;;

    launch)
        name="${2:-}"
        [[ -z "$name" ]] && { echo "Usage: web-app launch <name>" >&2; exit 1; }
        id="$(_id_of "$name")"
        if [[ -z "$id" ]]; then
            echo "web-app: no PWA named '$name'. Available:" >&2
            firefoxpwa profile list 2>/dev/null | grep -E 'Name:' >&2
            exit 1
        fi
        firefoxpwa site launch "$id"
        ;;

    list)
        firefoxpwa profile list
        ;;

    remove|uninstall)
        name="${2:-}"
        [[ -z "$name" ]] && { echo "Usage: web-app remove <name>" >&2; exit 1; }
        id="$(_id_of "$name")"
        [[ -z "$id" ]] && { echo "web-app: no PWA named '$name'." >&2; exit 1; }
        firefoxpwa site uninstall "$id"
        ;;

    help|"")
        sed -n '2,15p' "$0"
        ;;

    *)
        echo "web-app: unknown command: $1" >&2
        echo "Try: web-app help" >&2
        exit 1
        ;;
esac
