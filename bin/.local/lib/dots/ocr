#!/usr/bin/env bash
# dots:summary=OCR a screen region → clipboard (tesseract)
# dots:args=[eng|por|eng+por]
set -euo pipefail

command -v tesseract >/dev/null || { dots notify "OCR" "tesseract not installed" -a ocr -i dialog-error; exit 1; }

lang="${1:-eng+por}"
tmp="$(mktemp --suffix=.png)"
trap 'rm -f "$tmp" "${tmp%.png}.txt"' EXIT

grim -g "$(slurp)" "$tmp" 2>/dev/null || exit 0

out_base="${tmp%.png}"
tesseract "$tmp" "$out_base" -l "$lang" 2>/dev/null

text="$(cat "${out_base}.txt")"
[[ -z "${text// /}" ]] && { dots notify "OCR" "no text detected" -a ocr -i dialog-warning; exit 0; }

printf '%s' "$text" | wl-copy
preview="${text:0:200}"
[[ ${#text} -gt 200 ]] && preview="${preview}…"
dots notify "OCR copied" "$preview" -a ocr -i edit-copy -t 4000
