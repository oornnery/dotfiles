#!/usr/bin/env bash
# dots:summary=Schedule a desktop notification reminder
# dots:args=<minutes> [message] | show | clear
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dots/reminders"
mkdir -p "$STATE_DIR"

_fmt() { local s=$1 m=$((s / 60)) r=$((s % 60)); if ((m > 0 && r > 0)); then echo "${m}m ${r}s"; elif ((m > 0)); then echo "${m}m"; else echo "${r}s"; fi; }

cmd="${1:-}"
case "$cmd" in
    show)
        found=0
        for f in "$STATE_DIR"/*.reminder; do
            [[ -f "$f" ]] || continue
            target=$(head -1 "$f" 2>/dev/null); msg=$(tail -n +2 "$f" 2>/dev/null); now=$(date +%s)
            if (( target > now )); then printf '  %s — %s\n' "$(_fmt $((target - now)))" "${msg:-(no message)}"; found=1; fi
        done
        (( found == 0 )) && echo "(no pending reminders)" || true ;;
    clear) rm -f "$STATE_DIR"/*.reminder; echo "All reminders cleared." ;;
    "") echo "Usage: dots reminder <minutes> [message] | show | clear" >&2; exit 1 ;;
    *)
        if [[ "$cmd" =~ ^[0-9]+$ ]]; then
            mins="$cmd"; shift; msg="${*:-Reminder}"
            target=$(( $(date +%s) + mins * 60 )); file="$STATE_DIR/${target}_$$.reminder"
            { echo "$target"; echo "$msg"; } > "$file"
            ( sleep "${mins}m"; if [[ -f "$file" ]]; then dots notify "Reminder" "$msg" -g "⏰" -u critical -t 0; rm -f "$file"; fi ) &
            disown
            dots notify "Reminder set" "$(_fmt $((mins * 60))): $msg" -g "⏱️"
        else
            echo "Unknown command: $cmd" >&2; exit 1
        fi ;;
esac
