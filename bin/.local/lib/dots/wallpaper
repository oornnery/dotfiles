#!/usr/bin/env bash
# dots:summary=Manage hyprpaper wallpaper
# dots:args=(get)|list|next|prev|random|set <path>
set -euo pipefail

DIR="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"
STATE="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles/active-wallpaper"
mkdir -p "$(dirname "$STATE")" "$DIR"

_list() {
    find "$DIR" -maxdepth 2 -type f \
        \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) | sort
}
_current() { [[ -f "$STATE" ]] && cat "$STATE" || echo ""; }
_apply() {
    local path="$1"
    [[ -f "$path" ]] || { echo "dots wallpaper: file not found: $path" >&2; exit 1; }
    hyprctl hyprpaper preload "$path" >/dev/null
    while IFS= read -r mon; do hyprctl hyprpaper wallpaper "$mon,$path" >/dev/null; done \
        < <(hyprctl monitors -j | jq -r '.[].name')
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$path" >/dev/null
    echo "$path" > "$STATE"
    dots notify "Wallpaper" "$(basename "$path")" -a wallpaper -i "$path" -t 3000
}

cmd="${1:-get}"; shift || true
case "$cmd" in
    ""|get) _current ;;
    list)   _list ;;
    next|prev)
        mapfile -t files < <(_list)
        (( ${#files[@]} == 0 )) && { echo "dots wallpaper: no images in $DIR" >&2; exit 1; }
        cur="$(_current)"; idx=0
        for i in "${!files[@]}"; do [[ "${files[i]}" == "$cur" ]] && { idx=$i; break; }; done
        if [[ "$cmd" == next ]]; then idx=$(( (idx + 1) % ${#files[@]} ))
        else idx=$(( (idx - 1 + ${#files[@]}) % ${#files[@]} )); fi
        _apply "${files[idx]}" ;;
    random)
        mapfile -t files < <(_list)
        (( ${#files[@]} == 0 )) && { echo "dots wallpaper: no images in $DIR" >&2; exit 1; }
        _apply "${files[$RANDOM % ${#files[@]}]}" ;;
    set)
        [[ -z "${1:-}" ]] && { echo "Usage: dots wallpaper set <path>" >&2; exit 1; }
        _apply "$1" ;;
    -h|--help|help) sed -n '2,3p' "$0" ;;
    *) echo "dots wallpaper: unknown action: $cmd" >&2; exit 1 ;;
esac
