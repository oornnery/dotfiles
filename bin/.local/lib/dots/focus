#!/usr/bin/env bash
# dots:summary=Launch an app or focus an existing window matching a pattern
# dots:args=<window-pattern> [launch-cmd [args…]]
set -euo pipefail

(($# == 0)) && { echo "Usage: dots focus <window-pattern> [launch-cmd [args…]]" >&2; exit 1; }

WINDOW_PATTERN="$1"; shift
if (($# > 0)); then LAUNCH_CMD=("$@"); else LAUNCH_CMD=("$WINDOW_PATTERN"); fi

WINDOW_ADDRESS=$(hyprctl clients -j 2>/dev/null \
    | jq -r --arg p "$WINDOW_PATTERN" \
        '.[] | select((.class | test("\\b" + $p + "\\b"; "i")) or (.title | test("\\b" + $p + "\\b"; "i"))) | .address' \
    | head -1)

if [[ -n "$WINDOW_ADDRESS" ]]; then
    hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS" >/dev/null
else
    setsid -f "${LAUNCH_CMD[@]}" >/dev/null 2>&1
fi
