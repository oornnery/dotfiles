#!/usr/bin/env bash
# dots:summary=Send a notification (glyph presets, consistent app-id)
# dots:args=<title> [body] [-g glyph][-u urg][-t ms][-a app][-i icon][-r id][-h hint]
#
# Thin notify-send wrapper. -r/--replace-id + -h/--hint forward straight through,
# so OSD-style progress bars work: dots notify "Volume" -r 9 -h int:value:60
set -euo pipefail

TITLE=""; BODY=""; GLYPH=""; URGENCY="normal"; TIMEOUT="3000"; APP="dots"
ICON=""; REPLACE=""; HINTS=()

while (($#)); do
    case "$1" in
        -g|--glyph)      GLYPH="$2"; shift 2 ;;
        -u|--urgency)    URGENCY="$2"; shift 2 ;;
        -t|--timeout)    TIMEOUT="$2"; shift 2 ;;
        -a|--app)        APP="$2"; shift 2 ;;
        -i|--icon)       ICON="$2"; shift 2 ;;
        -r|--replace-id) REPLACE="$2"; shift 2 ;;
        -h|--hint)       HINTS+=("$2"); shift 2 ;;
        *)
            if   [[ -z "$TITLE" ]]; then TITLE="$1"
            elif [[ -z "$BODY"  ]]; then BODY="$1"
            fi
            shift ;;
    esac
done

[[ -z "$TITLE" ]] && { echo "Usage: dots notify <title> [body] [-g glyph][-i icon][-r id][-h hint]" >&2; exit 1; }

DISPLAY_TITLE="$TITLE"
[[ -n "$GLYPH" ]] && DISPLAY_TITLE="$GLYPH  $TITLE"

args=(-a "$APP" -u "$URGENCY" -t "$TIMEOUT")
[[ -n "$ICON"    ]] && args+=(-i "$ICON")
[[ -n "$REPLACE" ]] && args+=(-r "$REPLACE")
for h in "${HINTS[@]:-}"; do [[ -n "$h" ]] && args+=(-h "$h"); done

notify-send "${args[@]}" "$DISPLAY_TITLE" "$BODY"
