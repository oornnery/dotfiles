#!/usr/bin/env bash
# dots:summary=Notification history (restore/dismiss/clear/list/pick/dnd)
# dots:args=restore|dismiss|clear|list|pick|dnd
set -euo pipefail

command -v makoctl >/dev/null || { dots notify "Notifications" "mako not running" -a dots-notifications -i dialog-error; exit 1; }

case "${1:-help}" in
    restore) makoctl restore 2>/dev/null || dots notify "Notifications" "No history to restore" -a dots-notifications -t 1500 ;;
    dismiss) makoctl dismiss 2>/dev/null || true ;;
    clear|dismiss-all) makoctl dismiss --all 2>/dev/null || true ;;
    list)    makoctl list ;;
    pick)
        lines="$(makoctl list 2>/dev/null | jq -r '.data[][] | "\(.id.data)\t\(.["app-name"].data) — \(.summary.data)"' 2>/dev/null)"
        [[ -z "$lines" ]] && { dots notify "Notifications" "No active notifications" -a dots-notifications -t 1500; exit 0; }
        pick="$(printf '%s\n' "$lines" | dots menu 'Notification:')"; [[ -z "$pick" ]] && exit 0
        id="${pick%%$'\t'*}"
        makoctl invoke -n "$id" default 2>/dev/null || makoctl invoke -n "$id" 2>/dev/null || true ;;
    toggle-dnd|dnd) exec dots dnd ;;
    -h|--help|help|"") sed -n '2,3p' "$0" ;;
    *) echo "dots notifications: unknown action: $1" >&2; exit 1 ;;
esac
