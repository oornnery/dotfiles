#!/usr/bin/env bash
# dots:summary=Obsidian vault helper (today/new/find/search/open)
# dots:args=new "Title"|today|find|search [Q]|open <file>|obsidian
set -uo pipefail

VAULT="${OBSIDIAN_VAULT:-$HOME/Documents/vault}"
DAILY="$VAULT/Daily"
EDITOR="${EDITOR:-nvim}"
mkdir -p "$VAULT" "$DAILY"

_open_editor() {
    local file="$1" line="${2:-1}"
    if [[ -n "${TMUX:-}" ]] || [[ -t 1 ]]; then
        "$EDITOR" "+$line" "$file"
    else
        setsid -f alacritty --class floating -e "$EDITOR" "+$line" "$file" >/dev/null 2>&1 &
    fi
}

_open_obsidian() {
    local file="$1" rel="${file#"$VAULT"/}" vault_name enc
    vault_name="$(basename "$VAULT")"
    enc="$(printf '%s' "${rel%.md}" | sed 's/ /%20/g')"
    xdg-open "obsidian://open?vault=$vault_name&file=$enc" >/dev/null 2>&1 &
}

case "${1:-help}" in
    new)
        shift
        title="${*:?Usage: dots obsidian new <title>}"
        ts="$(date +%Y-%m-%d)"
        slug="$(printf '%s' "$title" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')"
        file="$VAULT/$ts-$slug.md"
        if [[ -e "$file" ]]; then
            dots notify "Note exists" "$file" -a obsidian
        else
            cat > "$file" <<EOF
---
title: $title
date: $ts
tags: []
---

# $title

EOF
            dots notify "Note created" "$file" -a obsidian
        fi
        _open_editor "$file" ;;

    today|daily)
        ts="$(date +%Y-%m-%d)"
        file="$DAILY/$ts.md"
        if [[ ! -f "$file" ]]; then
            cat > "$file" <<EOF
---
date: $ts
day: $(date +%A)
tags: [daily]
---

# $(date '+%A, %B %d, %Y')

## Notes

## Tasks

- [ ]

## Links

EOF
        fi
        _open_editor "$file" ;;

    find)
        pick="$(find "$VAULT" -name '*.md' -type f -printf '%P\n' 2>/dev/null | sort | dots menu 'Note:')" || exit 0
        [[ -z "$pick" ]] && exit 0
        _open_editor "$VAULT/$pick" ;;

    search)
        shift || true
        query="${*:-}"
        [[ -z "$query" ]] && { query="$(printf '' | dots menu 'Search vault:')" || exit 0; }
        [[ -z "$query" ]] && exit 0
        result="$(rg --color=never --line-number --no-heading "$query" "$VAULT" --type md 2>/dev/null | sed -E "s|^$VAULT/||" | dots menu 'Match:')" || exit 0
        [[ -z "$result" ]] && exit 0
        file="${result%%:*}"; line="$(printf '%s' "$result" | cut -d: -f2)"
        _open_editor "$VAULT/$file" "$line" ;;

    open) _open_editor "${2:?Usage: dots obsidian open <file>}" ;;

    obsidian|gui)
        pick="$(find "$VAULT" -name '*.md' -type f -printf '%P\n' 2>/dev/null | sort | dots menu 'Open in Obsidian:')" || exit 0
        [[ -z "$pick" ]] && exit 0
        _open_obsidian "$VAULT/$pick" ;;

    -h|--help|help) sed -n '2,3p' "$0" ;;
    *) echo "dots obsidian: unknown action: $1" >&2; exit 1 ;;
esac
