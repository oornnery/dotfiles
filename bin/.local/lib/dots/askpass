#!/usr/bin/env bash
# dots:summary=Password helper for sudo -A (SUDO_ASKPASS target)
# dots:hidden=true
#
# sudo invokes this with the prompt as $1 and reads the password from stdout.
# Wire up: export SUDO_ASKPASS=$HOME/.local/lib/dots/askpass; then `sudo -A …`.
set -uo pipefail

prompt="${1:-Password:}"
prompt="${prompt%:}"           # strip trailing colon
prompt="${prompt#\[sudo\] }"   # strip leading "[sudo] "

if command -v gum >/dev/null 2>&1; then
    gum input --password --header "󰣇 $prompt" --prompt "󰌾 " --width 60 \
        --header.foreground='212' --prompt.foreground='212' </dev/tty
elif command -v zenity >/dev/null 2>&1; then
    zenity --password --title "$prompt"
else
    read -rsp "$prompt: " p </dev/tty
    printf '\n' >&2
    printf '%s\n' "$p"
fi
