# ~/.config/mako/config — notification daemon.
#
# Colors come from ~/.config/mako/theme.config (managed by `theme set <name>`).
# Layout + typography + behavior live here.
# Reload after editing: `makoctl reload`.

include=/home/oornnery/.config/mako/theme.config

# Layout
anchor=top-right
margin=12
padding=12,16
border-radius=8
border-size=1
width=380
height=120
default-timeout=6000
ignore-timeout=0
group-by=app-name
max-visible=5
sort=-time

# Typography
font=JetBrainsMono Nerd Font 11

[urgency=low]
default-timeout=3000

[urgency=high]
default-timeout=0

# Hidden tray icons for these spammy apps
[summary~="Spotify"]
invisible=1

# ─── Action handlers (clicáveis) ───────────────────────────────────────────
# notify-send com summary específico aciona ações ao clicar na notif.

[summary="Update System"]
on-button-left=dismiss; exec alacritty -e bash -c 'update; read -p Done...'

[summary="Setup Wi-Fi"]
on-button-left=dismiss; exec floating-tui impala

[summary="Setup Bluetooth"]
on-button-left=dismiss; exec floating-tui bluetui

[summary="Learn Keybindings"]
on-button-left=dismiss; exec cheatsheet

[summary~="Screenshot.*"]
icon-size=80
markup=1

[urgency=critical]
default-timeout=0
layer=overlay
