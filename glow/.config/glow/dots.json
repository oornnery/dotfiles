{
  "document": { "block_prefix": "\n", "block_suffix": "\n", "color": "252", "margin": 2 },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "244" },
  "paragraph": {},
  "list": { "block_prefix": "\n", "block_suffix": "\n", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "39", "bold": true },
  "h1": { "prefix": " ", "suffix": " ", "color": "228", "background_color": "63", "bold": true },
  "h2": { "prefix": "", "color": "39", "bold": true },
  "h3": { "prefix": "", "color": "73", "bold": true },
  "h4": { "prefix": "", "color": "73", "bold": true },
  "h5": { "prefix": "", "color": "73", "bold": true },
  "h6": { "prefix": "", "color": "73" },
  "strikethrough": { "crossed_out": true },
  "emph": { "italic": true },
  "strong": { "bold": true },
  "hr": { "color": "240", "format": "\n──────────\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "30", "underline": true },
  "link_text": { "color": "35", "bold": true },
  "image": { "color": "212", "underline": true },
  "image_text": { "color": "243", "format": "Image: {{.text}} →" },
  "code": { "prefix": " ", "suffix": " ", "color": "203", "background_color": "236" },
  "code_block": {
    "color": "244",
    "margin": 2,
    "chroma": {
      "text": { "color": "#C4C4C4" },
      "keyword": { "color": "#F92672" },
      "literal_string": { "color": "#E6DB74" },
      "name_function": { "color": "#66D9EF" },
      "name_builtin": { "color": "#A6E22E" },
      "comment": { "color": "#75715E" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_description": { "block_prefix": "\n🠶 " }
}
