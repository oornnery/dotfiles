.*_cache/
.env

# Bootstrap runtime log (lib/common.sh appends here).
arch.log
scripts/arch/lib/arch.log

# Claude Code local state
.claude/

# Python bytecode caches (fabric-shell etc.)
__pycache__/
*.pyc

.config/Code/*
!.config/Code/User/
.config/Code/User/*
!.config/Code/User/settings.json
!.config/Code/User/keybindings.json

vscode/.config/Code/*
!vscode/.config/Code/User/
vscode/.config/Code/User/*
!vscode/.config/Code/User/settings.json
!vscode/.config/Code/User/keybindings.json

.venv/
node_modules/
@girs/
theme.scss
windows/yasb/*.log

*.log

# starship binary (install via pacman/bootstrap, not committed)
bin/.local/bin/starship

# AI agent tool binaries — installed by their own toolchains, not user scripts.
# claude, codex, rtk: version-managed symlinks/binary blobs
bin/.local/bin/claude
bin/.local/bin/codex
bin/.local/bin/rtk

# oh-my-openagent (omo) — generated runtime, not user scripts
bin/.local/bin/omo
bin/.local/bin/omo-*

# Python runtime binaries (installed by system/pipx, not user scripts)
bin/.local/bin/python*

# Skills CLI cache and lockfile (managed by `npx skills`, not user scripts)
.agents/
skills-lock.json

# Local downloads and app runtime state
antigen.zsh
herdr/.config/herdr/session.json
herdr/.config/herdr/*.log

# OpenCode local state, caches, and generated files
.config/opencode/node_modules/
.config/opencode/package.json
.config/opencode/package-lock.json
.config/opencode/.git/
.config/opencode/.gitignore
.config/opencode/*.backup-*
.config/opencode/.ktx/
.config/opencode/ktx.yaml
.config/opencode/.omo/
opencode/.config/opencode/plugins/
.config/opencode/raw-sources/
.config/opencode/semantic-layer/
.config/opencode/wiki/
opencode.slim/.config/opencode/node_modules/
opencode.slim/.config/opencode/package.json
opencode.slim/.config/opencode/package-lock.json
opencode.slim/.config/opencode/.git/
opencode.slim/.config/opencode/.gitignore
opencode.slim/.config/opencode/*.backup-*
opencode.slim/.config/opencode/.ktx/
opencode.slim/.config/opencode/ktx.yaml
opencode.slim/.config/opencode/.omo/
opencode.slim/.config/opencode/raw-sources/
opencode.slim/.config/opencode/semantic-layer/
opencode.slim/.config/opencode/wiki/
opencode.slim/.config/opencode/plugins/caveman/package.json
opencode.slim/.config/opencode/plugins/caveman/package-lock.json
opencode.slim/.config/opencode/plugins/caveman/node_modules/
