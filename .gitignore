.*_cache/
.env

# Bootstrap runtime log (lib/common.sh appends here).
arch.log
scripts/arch/lib/arch.log

# Claude Code local state
.claude/

# Python bytecode caches (fabric-shell etc.)
__pycache__/
*.pyc

.config/Code/*
!.config/Code/User/
.config/Code/User/*
!.config/Code/User/settings.json
!.config/Code/User/keybindings.json

vscode/.config/Code/*
!vscode/.config/Code/User/
vscode/.config/Code/User/*
!vscode/.config/Code/User/settings.json
!vscode/.config/Code/User/keybindings.json

.venv/
node_modules/
@girs/
theme.scss
windows/yasb/*.log

*.log

# starship binary (install via pacman/bootstrap, not committed)
bin/.local/bin/starship

# AI agent tool binaries — installed by their own toolchains, not user scripts.
# claude, codex, rtk: version-managed symlinks/binary blobs
bin/.local/bin/claude
bin/.local/bin/codex
bin/.local/bin/rtk

# oh-my-openagent (omo) — generated runtime, not user scripts
bin/.local/bin/omo
bin/.local/bin/omo-*
